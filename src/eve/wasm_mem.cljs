;; HAMT Operations
;;-----------------------------------------------------------------------------

(defn hamt-find
  "Full HAMT lookup in WASM.

   Parameters:
   - root-off: Root node offset (-1 for empty)
   - target-ptr: Offset of serialized key bytes in memory
   - target-len: Length of key bytes
   - key-hash: FNV-1a hash of key
   - cljs-hash: ClojureScript hash for HAMT navigation
   - shift: Current shift level (0 for root)

   Returns val-offset (>= 0) if found, -1 if not found.
   val-offset points to [len:u32][bytes...]"
  [root-off target-ptr target-len key-hash cljs-hash shift]
  (if cached-exports
    (let [result (.hamt_find cached-exports
                             root-off target-ptr target-len
                             key-hash cljs-hash shift)]
      (if (zero? (bit-and result 1))
        -1
        (unsigned-bit-shift-right result 1)))
    -1))

;;-----------------------------------------------------------------------------
;; HAMT Batch Iteration
;;-----------------------------------------------------------------------------

(def ^:const MAX_COLLECT_ENTRIES 15000)

(defn hamt-collect-kv
  "Collect all KV entry offsets from a HAMT tree into a flat buffer.
   Uses the scratch region as output buffer.

   Parameters:
   - root-off: Root node offset (-1 for empty)
   - out-buf: Output buffer offset (scratch region start)
   - max-entries: Max entries to collect

   Returns number of entries written.
   Output format: [key_off:i32, key_len:i32, val_off:i32, val_len:i32] × N"
  [root-off out-buf max-entries]
  (when cached-exports
    (.hamt_collect_kv cached-exports root-off out-buf max-entries)))

(defn hamt-reduce-sum
  "Sum all numeric values in a HAMT tree entirely in WASM.
   Returns f64 sum, or nil if non-numeric values encountered or WASM not ready.
   Uses stack-buf for explicit iteration stack."
  [root-off stack-buf]
  (when cached-exports
    (let [result (.hamt_reduce_sum cached-exports root-off stack-buf)]
      (when-not (js/isNaN result)
        result))))

(defn vec-collect-values
  "Collect [val_data_off, val_data_len] for all elements in a SabVec.
   Walks the 32-way trie + tail in order, writing to out-buf.
   Output format: [val_data_off:i32, val_data_len:i32] × N"
  [root tail cnt shift tail-len out-buf max-entries]
  (when cached-exports
    (.vec_collect_values cached-exports
                         root tail cnt shift tail-len out-buf max-entries)))

(defn deser-tag-info
  "WASM fast-path tag dispatch for deserialization.
   Validates magic prefix (0xEE 0xDB), reads tag byte, dispatches via br_table.
   Writes [payload_start:i32, payload_val:i32] to out-buf.
   Returns tag (0x01-0x1A), 0 for nil, -1 for bad magic/unknown."
  [off len out-buf]
  (when cached-exports
    (.deser_tag_info cached-exports off len out-buf)))

;;-----------------------------------------------------------------------------
;; Batch Operations
;;-----------------------------------------------------------------------------

(defn gather-u32!
  "Gather u32 values from offsets array to output array."
  [offsets-ptr output-ptr count]
  (when cached-exports
    (.gather_u32 cached-exports offsets-ptr output-ptr count)))

(defn scatter-u32!
  "Scatter u32 values from input array to offsets."
  [offsets-ptr input-ptr count]
  (when cached-exports
    (.scatter_u32 cached-exports offsets-ptr input-ptr count)))

(defn prefix-sum-u32!
  "Compute exclusive prefix sum of u32 array."
  [input-ptr output-ptr count initial]
  (when cached-exports
    (.prefix_sum_u32 cached-exports input-ptr output-ptr count initial)))

;;-----------------------------------------------------------------------------
;; SIMD Batch Array Operations
;;-----------------------------------------------------------------------------

(defn simd-fill-i32!
  "Fill i32 array with a value using SIMD.
   Processes 4 elements at a time with v128.
   Parameters:
   - ptr: byte offset in memory
   - count: number of i32 elements
   - value: i32 value to fill"
  [ptr count value]
  (when cached-exports
    (.simd_fill_i32 cached-exports ptr count value)))

(defn simd-copy-i32!
  "Copy i32 array using SIMD.
   Processes 4 elements at a time with v128.
   Parameters:
   - dst-ptr: destination byte offset
   - src-ptr: source byte offset
   - count: number of i32 elements"
  [dst-ptr src-ptr count]
  (when cached-exports
    (.simd_copy_i32 cached-exports dst-ptr src-ptr count)))

(defn simd-sum-i32
  "Sum i32 array using SIMD.
   Processes 4 elements at a time with i32x4.add.
   Parameters:
   - ptr: byte offset in memory
   - count: number of i32 elements
   Returns: sum as i32"
  [ptr count]
  (if cached-exports
    (.simd_sum_i32 cached-exports ptr count)
    0))

(defn simd-min-i32
  "Find minimum value in i32 array using SIMD.
   Processes 4 elements at a time with i32x4.min_s.
   Parameters:
   - ptr: byte offset in memory
   - count: number of i32 elements
   Returns: minimum value (or INT32_MAX for empty array)"
  [ptr count]
  (if cached-exports
    (.simd_min_i32 cached-exports ptr count)
    2147483647))

(defn simd-max-i32
  "Find maximum value in i32 array using SIMD.
   Processes 4 elements at a time with i32x4.max_s.
   Parameters:
   - ptr: byte offset in memory
   - count: number of i32 elements
   Returns: maximum value (or INT32_MIN for empty array)"
  [ptr count]
  (if cached-exports
    (.simd_max_i32 cached-exports ptr count)
    -2147483648))

(defn simd-eq-i32?
  "Compare two i32 arrays for equality using SIMD.
   Processes 4 elements at a time with i32x4.eq.
   Parameters:
   - ptr1: first array byte offset
   - ptr2: second array byte offset
   - count: number of i32 elements
   Returns: true if all elements are equal"
  [ptr1 ptr2 count]
  (if cached-exports
    (== 1 (.simd_eq_i32 cached-exports ptr1 ptr2 count))
    false))

;;-----------------------------------------------------------------------------
;; Descriptor Table WASM Scan
;;-----------------------------------------------------------------------------

(defn find-free-descriptor
  "WASM-accelerated scan for a free descriptor with sufficient capacity.
   Returns descriptor index or -1 if not found.
   Falls back to -1 if WASM not ready (caller uses JS scan fallback)."
  [base-byte max-count min-capacity start-idx]
  (if cached-exports
    (.find_free_descriptor cached-exports
                           base-byte max-count min-capacity start-idx)
    -1))

(defn find-free-descriptors-batch
  "WASM-accelerated batch scan for free descriptors with sufficient capacity.
   Writes up to max-results descriptor indices to out-ptr (i32 array in WASM memory).
   Returns count of found descriptors.
   Falls back to 0 if WASM not ready."
  [base-byte max-count min-capacity start-idx max-results out-ptr]
  (if cached-exports
    (.find_free_descriptors_batch cached-exports
                                  base-byte max-count min-capacity
                                  start-idx max-results out-ptr)
    0))

;; SIMD-accelerated descriptor scanning over SoA mirror arrays (Phase 1)

(defn find-free-descriptor-simd
  "SIMD-accelerated scan for first free descriptor with sufficient capacity.
   Scans contiguous status[] and capacity[] mirror arrays using v128 (4 descriptors/cycle).
   Returns descriptor index or -1."
  [status-arr capacity-arr count min-capacity start-idx]
  (if cached-exports
    (.find_free_descriptor_simd cached-exports
                                 status-arr capacity-arr count min-capacity start-idx)
    -1))

(defn find-free-descriptors-batch-simd
  "SIMD-accelerated batch scan for free descriptors over SoA mirrors.
   Writes up to max-results indices to out-ptr (i32 array in WASM memory).
   Returns count found."
  [status-arr capacity-arr count min-capacity start-idx max-results out-ptr]
  (if cached-exports
    (.find_free_descriptors_batch_simd cached-exports
                                        status-arr capacity-arr count min-capacity
                                        start-idx max-results out-ptr)
    0))

(defn find-retired-descriptors-simd
  "SIMD-accelerated scan for retired descriptors (STATUS_RETIRED=5) over SoA status mirror.
   Writes up to max-results retired descriptor indices to out-ptr.
   Returns count found."
  [status-arr count out-ptr max-results]
  (if cached-exports
    (.find_retired_descriptors_simd cached-exports
                                     status-arr count out-ptr max-results)
    0))

;;-----------------------------------------------------------------------------
;; HAMT Node Builder Operations
;;-----------------------------------------------------------------------------

(defn calc-kv-total-size
  "Calculate total size (bytes) of all KV entries in a bitmap node.
   Falls back to 0 if WASM not ready (caller uses JS fallback)."
  [node-off data-bm node-bm]
  (if cached-exports
    (.calc_kv_total_size cached-exports node-off data-bm node-bm)
    0))

(defn build-node-replace-child!
  "Build a bitmap node at dst with one child pointer replaced.
   Copies header, children (replacing update-idx with new-child), and all KV data.
   Falls back to false if WASM not ready."
  [dst src data-bm node-bm update-idx new-child]
  (if cached-exports
    (do (.build_node_replace_child cached-exports
                                    dst src data-bm node-bm update-idx new-child)
        true)
    false))

(defn build-node-replace-kv!
  "Build a bitmap node at dst with one KV entry replaced.
   kb-ptr/vb-ptr must be offsets in SAB memory (e.g., scratch area).
   Falls back to false if WASM not ready."
  [dst src data-bm node-bm replace-idx kh kb-ptr kb-len vb-ptr vb-len]
  (if cached-exports
    (do (.build_node_replace_kv cached-exports
                                 dst src data-bm node-bm replace-idx kh
                                 kb-ptr kb-len vb-ptr vb-len)
        true)
    false))

(defn build-node-add-kv!
  "Build a bitmap node at dst with one KV entry added at insert-idx.
   kb-ptr/vb-ptr must be offsets in SAB memory (e.g., scratch area).
   Falls back to false if WASM not ready."
  [dst src src-data-bm src-node-bm new-data-bm insert-idx kh kb-ptr kb-len vb-ptr vb-len]
  (if cached-exports
    (do (.build_node_add_kv cached-exports
                             dst src src-data-bm src-node-bm new-data-bm insert-idx kh
                             kb-ptr kb-len vb-ptr vb-len)
        true)
    false))

(defn build-node-remove-kv-add-child!
  "Build a bitmap node at dst removing one KV entry and optionally inserting a child.
   insert-child-idx < 0 means no child insertion.
   Falls back to false if WASM not ready."
  [dst src src-data-bm src-node-bm new-data-bm new-node-bm remove-kv-idx insert-child-idx new-child]
  (if cached-exports
    (do (.build_node_remove_kv_add_child cached-exports
                                          dst src src-data-bm src-node-bm
                                          new-data-bm new-node-bm
                                          remove-kv-idx insert-child-idx new-child)
        true)
    false))

;;-----------------------------------------------------------------------------
;; Scratch Space Management
;;-----------------------------------------------------------------------------

(defn scratch-offset
  "Get scratch space offset for a worker slot.
   Each worker has SCRATCH_SIZE bytes of scratch space.
   IMPORTANT: slot-idx must be 0 to (MAX_WORKERS-1), NOT the random worker-id!"
  [slot-idx scratch-region-start]
  (when-not (and (>= slot-idx 0) (< slot-idx MAX_WORKERS))
    (throw (js/Error. (str "scratch-offset: slot-idx " slot-idx " out of bounds [0, " MAX_WORKERS ")"))))
  (+ scratch-region-start (* slot-idx SCRATCH_SIZE)))

(defn copy-to-scratch!
  "Copy bytes to worker's scratch area.
   Returns the scratch offset where data was written.
   IMPORTANT: slot-idx must be 0 to (MAX_WORKERS-1), NOT the random worker-id!"
  [slot-idx scratch-region-start ^js bytes]
  (let [off (scratch-offset slot-idx scratch-region-start)
        len (.-length bytes)]
    (when (<= len SCRATCH_SIZE)
      (.set @mem-u8 bytes off)
      off)))
