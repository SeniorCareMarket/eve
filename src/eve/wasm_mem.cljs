(ns eve.wasm-mem
  "Unified WASM Memory backend for EVE.

   All EVE data structures use WebAssembly.Memory for storage.
   This module provides:
   1. Memory creation and management
   2. Core WASM primitives (popcount, memcmp, memcpy, etc.)
   3. SIMD-accelerated operations (v128 compare, hash, etc.)
   4. HAMT operations (lookup, assoc, dissoc)
   5. Batch operations (gather, scatter, reduce)

   ARCHITECTURE:
   ═══════════════════════════════════════════════════════════════

   ┌─────────────────────────────────────────────────────────────┐
   │                    User API Layer                           │
   │  eve-obj  │  eve-array  │ eve-map   │  eve-vec  │  eve-set  │
   └─────────────────────────────────────────────────────────────┘
                              │
                              ▼
   ┌─────────────────────────────────────────────────────────────┐
   │                    wasm-mem (this module)                   │
   │  Memory mgmt  │  Primitives  │  SIMD ops  │  HAMT ops      │
   └─────────────────────────────────────────────────────────────┘
                              │
                              ▼
   ┌─────────────────────────────────────────────────────────────┐
   │                  WebAssembly.Memory (shared)                │
   │  Zero-copy access from JS and WASM                         │
   └─────────────────────────────────────────────────────────────┘

   MEMORY LAYOUT:
   ═══════════════════════════════════════════════════════════════

   ┌──────────────────────────────────────────────────────────────┐
   │ Index Region (metadata, block descriptors, worker registry) │
   ├──────────────────────────────────────────────────────────────┤
   │ Scratch Region (per-worker scratch space for WASM ops)      │
   ├──────────────────────────────────────────────────────────────┤
   │ Data Region (all allocated data: nodes, values, etc.)       │
   └──────────────────────────────────────────────────────────────┘

   ═══════════════════════════════════════════════════════════════")

;;-----------------------------------------------------------------------------
;; Module State
;;-----------------------------------------------------------------------------

(defonce ^:private wasm-module (atom nil))
(defonce ^:private wasm-memory (atom nil))
(defonce wasm-ready (atom false))
(defonce ^:private init-promise (atom nil))

;; Views for direct memory access (atoms for compatibility)
(defonce ^:private mem-u8 (atom nil))   ;; Uint8Array view
(defonce ^:private mem-i32 (atom nil))  ;; Int32Array view
(defonce ^:private mem-f64 (atom nil))  ;; Float64Array view
(defonce ^:private mem-dv (atom nil))   ;; DataView for unaligned access

;; Fast-path cached views — direct JS variable access avoids
;; CLJS atom deref protocol dispatch (~20-50ns per call).
;; Updated alongside atoms in init/update functions.
(def ^:private ^:mutable cached-u8 nil)
(def ^:private ^:mutable cached-i32 nil)
(def ^:private ^:mutable cached-f64 nil)
(def ^:private ^:mutable cached-dv nil)
;; Cached WASM exports object — avoids 2 atom derefs (@wasm-ready + @wasm-module)
;; per WASM function call. Updated when WASM module is (re)initialized.
(def ^:private ^:mutable ^js cached-exports nil)

;;-----------------------------------------------------------------------------
;; Constants
;;-----------------------------------------------------------------------------

(def ^:const PAGE_SIZE 65536)           ;; WASM page size (64KB)
(def ^:const MAX_PAGES 16384)           ;; Max 1GB

;; SCRATCH SPACE:
;; Each worker gets a scratch area for WASM operations.
;; Used when doing HAMT lookups - we copy the serialized key bytes here
;; so WASM can read them (WASM can only access the shared memory).
;; 4KB per worker is enough for most keys (keywords, strings, etc.)
(def ^:const SCRATCH_SIZE 4096)         ;; Per-worker scratch (4KB)
(def ^:const MAX_WORKERS 256)           ;; Max concurrent workers (256 × 4KB = 1MB scratch)

;; Node types (matching sab_map.cljs)
(def ^:const NODE_TYPE_BITMAP 1)
(def ^:const NODE_TYPE_COLLISION 3)
(def ^:const NODE_TYPE_BITMAP_HASHED 5)  ;; Enhanced with per-key hashes

;; Header sizes
(def ^:const BITMAP_HEADER_SIZE 10)     ;; type:u8 pad:u8 data_bm:u32 node_bm:u32
(def ^:const COLLISION_HEADER_SIZE 8)   ;; type:u8 count:u8 pad:u16 hash:i32

