;;-----------------------------------------------------------------------------
;; Memory Management
;;-----------------------------------------------------------------------------

(defn create-memory
  "Create a WebAssembly.Memory for EVE.
   All data structures will use this memory.

   Parameters:
   - size-mb: Size in megabytes (will be rounded to 64KB page boundary)

   Returns: WebAssembly.Memory (shared)"
  [size-mb]
  (let [bytes (* size-mb 1024 1024)
        pages (js/Math.ceil (/ bytes PAGE_SIZE))]
    (js/WebAssembly.Memory.
     #js {:initial pages
          :maximum MAX_PAGES
          :shared true})))

(defn get-memory
  "Get the current WebAssembly.Memory instance.
   Returns nil if not initialized."
  []
  @wasm-memory)

(defn get-buffer
  "Get the SharedArrayBuffer backing the WASM memory.
   This is the buffer used by all EVE data structures."
  []
  (when-let [mem @wasm-memory]
    (.-buffer mem)))

;;-----------------------------------------------------------------------------
;; Memory Views
;;-----------------------------------------------------------------------------

(defn u8-view
  "Get Uint8Array view of the memory."
  []
  cached-u8)

(defn i32-view
  "Get Int32Array view of the memory."
  []
  cached-i32)

(defn f64-view
  "Get Float64Array view of the memory."
  []
  cached-f64)

(defn data-view
  "Get DataView for unaligned access."
  []
  cached-dv)

;;-----------------------------------------------------------------------------
;; Initialization
;;-----------------------------------------------------------------------------

(defn- update-cached-views!
  "Update fast-path cached view variables. Called after atom resets."
  []
  (set! cached-u8 @mem-u8)
  (set! cached-i32 @mem-i32)
  (set! cached-f64 @mem-f64)
  (set! cached-dv @mem-dv))

(defn init-views-from-sab!
  "Initialize typed array views from a raw SharedArrayBuffer.
   Use in worker threads where the SAB is received, not created via
   WebAssembly.Memory. Does NOT initialize WASM module (uses JS fallbacks)."
  [sab]
  (reset! mem-u8 (js/Uint8Array. sab))
  (reset! mem-i32 (js/Int32Array. sab))
  (reset! mem-f64 (js/Float64Array. sab))
  (reset! mem-dv (js/DataView. sab))
  (update-cached-views!))

(defn init!
  "Initialize the WASM memory backend.

   Parameters:
   - memory: WebAssembly.Memory (shared) - the memory to use

   Returns a promise that resolves when ready.
   Uses pre-compiled WASM binary - no external dependencies needed."
  [memory]
  (if-let [existing @init-promise]
    existing
    (do
      ;; Create typed views synchronously so they're available immediately
      ;; (WASM module compilation is async, but views only need the memory buffer)
      (reset! wasm-memory memory)
      (let [buffer (.-buffer memory)]
        (reset! mem-u8 (js/Uint8Array. buffer))
        (reset! mem-i32 (js/Int32Array. buffer))
        (reset! mem-f64 (js/Float64Array. buffer))
        (reset! mem-dv (js/DataView. buffer))
        (update-cached-views!))
      (let [p (-> (js/WebAssembly.instantiate
                   wasm-bytes
                   #js {:env #js {:memory memory}})
                  (.then (fn [result]
                           ;; Guard: only set exports if this memory is still current.
                           ;; update-views! may have replaced @wasm-memory with a new
                           ;; atom's memory while this async compilation was pending.
                           ;; Without this check, the stale callback overwrites
                           ;; cached-exports with the wrong WASM instance.
                           (when (identical? memory @wasm-memory)
                             (reset! wasm-module (.-instance result))
                             (set! cached-exports (.-exports (.-instance result)))
                             (reset! wasm-ready true))
                           true))
                  (.catch (fn [err]
                            (js/console.error "wasm-mem init failed:" err)
                            (throw err))))]
        (reset! init-promise p)
        p))))

(defn update-views!
  "Update typed array views for a new WebAssembly.Memory.
   Call after creating a new atom-domain with different memory.
   Synchronously updates JS views; WASM functions use JS fallbacks
   until the module is re-initialized."
  [memory]
  (reset! wasm-memory memory)
  (let [buffer (.-buffer memory)]
    (reset! mem-u8 (js/Uint8Array. buffer))
    (reset! mem-i32 (js/Int32Array. buffer))
    (reset! mem-f64 (js/Float64Array. buffer))
    (reset! mem-dv (js/DataView. buffer))
    (update-cached-views!))
  ;; Re-instantiate WASM module synchronously with new memory.
  ;; WebAssembly.Module/Instance sync constructors work in Node.js.
  (try
    (let [module (js/WebAssembly.Module. wasm-bytes)
          instance (js/WebAssembly.Instance. module #js {:env #js {:memory memory}})]
      (reset! wasm-module instance)
      (set! cached-exports (.-exports instance))
      (reset! wasm-ready true)
      (reset! init-promise (js/Promise.resolve true)))
    (catch :default _
      ;; Sync instantiation failed — fall back to no-WASM mode
      (reset! wasm-ready false)
      (reset! wasm-module nil)
      (set! cached-exports nil)
      (reset! init-promise nil))))

(defn ready?
  "Check if WASM memory backend is initialized."
  []
  (some? cached-exports))

;;-----------------------------------------------------------------------------
;; Core Primitives (exposed to ClojureScript)
;;-----------------------------------------------------------------------------

(defn popcount32
  "Count set bits in a 32-bit integer."
  [n]
  (if cached-exports
    (.popcount32 cached-exports n)
    ;; JS fallback (should never be needed)
    (let [n (bit-and n 0xFFFFFFFF)
          n (- n (bit-and (unsigned-bit-shift-right n 1) 0x55555555))
          n (+ (bit-and n 0x33333333) (bit-and (unsigned-bit-shift-right n 2) 0x33333333))
          n (bit-and (+ n (unsigned-bit-shift-right n 4)) 0x0f0f0f0f)
          n (+ n (unsigned-bit-shift-right n 8))
          n (+ n (unsigned-bit-shift-right n 16))]
      (bit-and n 0x3f))))

(defn bytes-equal?
  "Compare two byte ranges in memory."
  [offset1 offset2 len]
  (if cached-exports
    (== 1 (.bytes_equal cached-exports offset1 offset2 len))
    ;; JS fallback
    (let [u8 @mem-u8]
      (loop [i 0]
        (if (>= i len)
          true
          (if (== (aget u8 (+ offset1 i)) (aget u8 (+ offset2 i)))
            (recur (inc i))
            false))))))

(defn memcpy!
  "Copy bytes from src to dst in memory. Falls back to JS if WASM not ready."
  [dst src len]
  (if cached-exports
    (.memcpy cached-exports dst src len)
    (when-let [u8 @mem-u8]
      (.copyWithin u8 dst src (+ src len)))))

(defn memset!
  "Fill memory region with a byte value. Falls back to JS if WASM not ready."
  [dst val len]
  (if cached-exports
    (.memset cached-exports dst val len)
    (when-let [u8 @mem-u8]
      (.fill u8 val dst (+ dst len)))))

(defn fnv1a-hash
  "Compute FNV-1a hash of bytes at given offset."
  [offset len]
  (if cached-exports
    (.fnv1a_hash cached-exports offset len)
    ;; JS fallback
    (let [u8 @mem-u8]
      (loop [i 0
             hash (int 0x811c9dc5)]
        (if (>= i len)
          hash
          (recur (inc i)
                 (imul (bit-xor hash (aget u8 (+ offset i)))
                       0x01000193)))))))

(defn bitmap-index
  "Get child index from bitmap: popcount of bits below target bit."
  [bitmap bit]
  (if cached-exports
    (.bitmap_index cached-exports bitmap bit)
    (popcount32 (bit-and bitmap (dec bit)))))

;;-----------------------------------------------------------------------------
;; SIMD Operations
;;-----------------------------------------------------------------------------

(defn v128-bytes-eq-16?
  "Compare 16 bytes at once using SIMD."
  [offset1 offset2]
  (when cached-exports
    (== 1 (.v128_bytes_eq_16 cached-exports offset1 offset2))))

(defn v128-find-u32
  "Search for a u32 value in an array using SIMD.
   Returns index or -1 if not found."
  [ptr len target]
  (when cached-exports
    (.v128_find_u32 cached-exports ptr len target)))

(defn v128-i32x4-eq-mask
  "Compare 4 i32 values with target, return bitmask of matches."
  [ptr target]
  (when cached-exports
    (.v128_i32x4_eq_mask cached-exports ptr target)))

